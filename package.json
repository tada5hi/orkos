{
    "name": "orkos",
    "version": "1.1.0",
    "type": "module",
    "description": "A lightweight modular application orchestrator for TypeScript with dependency-ordered startup, shutdown, and topological module resolution.",
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://github.com/tada5hi"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/tada5hi/orkos.git"
    },
    "main": "dist/index.mjs",
    "types": "dist/index.d.mts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        }
    },
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "build": "npm run build:js && npm run build:types",
        "build:js": "tsdown",
        "build:types": "tsc --noEmit",
        "test": "vitest --config test/vitest.config.ts --run",
        "test:coverage": "vitest --config test/vitest.config.ts --run --coverage",
        "lint": "eslint",
        "lint:fix": "npm run lint -- --fix",
        "prepare": "husky"
    },
    "keywords": [
        "typescript",
        "module-orchestrator",
        "lifecycle-management",
        "topological-sort",
        "dependency-resolution",
        "plugin-system",
        "modular-architecture",
        "application-framework",
        "startup-shutdown",
        "module-loader"
    ],
    "license": "MIT",
    "peerDependencies": {
        "eldin": ">=1.1.0"
    },
    "devDependencies": {
        "@tada5hi/commitlint-config": "^1.3.1",
        "@tada5hi/eslint-config": "^2.0.2",
        "@tada5hi/tsconfig": "^0.7.2",
        "@vitest/coverage-v8": "^4.1.2",
        "eldin": "^1.1.0",
        "eslint": "^10.1.0",
        "husky": "^9.1.7",
        "tsdown": "^0.21.5",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.2",
        "vitest": "^4.1.1"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@antfu/install-pkg": "^1.1.0",
        "ebec": "^2.3.0"
    }
}
